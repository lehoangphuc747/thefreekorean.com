---
import Layout from "../layouts/Layout.astro";

const sessionCookie = Astro.cookies.get("__session")?.value;

if (!sessionCookie) {
  return Astro.redirect("/signin");
}

let user = null;
try {
  const response = await fetch(
    `https://identitytoolkit.googleapis.com/v1/accounts:lookup?key=AIzaSyAbvorAF9gyGlF0FIyahIZfrRyFk9HpL3Q`,
    {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ idToken: sessionCookie }),
    }
  );
  const data = await response.json();
  if (data.users && data.users.length > 0) {
    user = data.users[0];
  }
} catch (error) {
  console.error("Error verifying token:", error);
}

if (!user) {
  Astro.cookies.delete("__session", { path: "/" });
  return Astro.redirect("/signin");
}
---

<Layout title="Dashboard" lang="vi">
  <main class="min-h-screen bg-gray-50 py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto">
      <div class="bg-white shadow rounded-lg p-6">
        <div class="flex items-center justify-between mb-6">
          <h1 class="text-2xl font-bold text-gray-900">
            Xin chào, {user.displayName || user.email}
          </h1>
          <form action="/api/auth/signout">
            <button type="submit" class="px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500">
              Đăng xuất
            </button>
          </form>
        </div>
        
        <div class="border-t border-gray-200 pt-4">
          <dl class="grid grid-cols-1 gap-x-4 gap-y-6 sm:grid-cols-2">
            <div>
              <dt class="text-sm font-medium text-gray-500">Email</dt>
              <dd class="mt-1 text-sm text-gray-900">{user.email}</dd>
            </div>
            <div>
              <dt class="text-sm font-medium text-gray-500">Họ tên</dt>
              <dd class="mt-1 text-sm text-gray-900">{user.displayName || "Chưa cập nhật"}</dd>
            </div>
            <div>
              <dt class="text-sm font-medium text-gray-500">UID</dt>
              <dd class="mt-1 text-sm text-gray-900">{user.localId}</dd>
            </div>
            <div>
              <dt class="text-sm font-medium text-gray-500">Email xác thực</dt>
              <dd class="mt-1 text-sm text-gray-900">{user.emailVerified ? "Có" : "Chưa"}</dd>
            </div>
          </dl>
        </div>
      </div>
    </div>
  </main>
</Layout>
