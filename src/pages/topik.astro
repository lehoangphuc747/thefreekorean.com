---
export const prerender = true;
import TopikLayout from '../layouts/TopikLayout.astro';
---

<TopikLayout 
  title="TOPIK"
  description="Thông tin về kỳ thi TOPIK - Test of Proficiency in Korean"
>
  <div class="max-w-7xl mx-auto px-4 py-12">
    <div class="text-center mb-12">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">
        TOPIK - Test of Proficiency in Korean
      </h1>
      <p class="text-xl text-gray-600">
        Tài liệu và thông tin về kỳ thi TOPIK
      </p>
    </div>

    <!-- Quick Links -->
    <div class="grid md:grid-cols-1 gap-6 max-w-2xl mx-auto">
      <a 
        href="/topik/tim-hieu"
        class="block p-6 bg-white rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 border-2 border-purple-200 hover:border-purple-400 transform hover:-translate-y-1"
      >
        <div class="flex items-center gap-4">
          <div class="w-16 h-16 bg-gradient-to-br from-purple-500 to-pink-600 rounded-xl flex items-center justify-center">
            <span class="text-3xl">📚</span>
          </div>
          <div>
            <h3 class="text-xl font-bold text-gray-900 mb-1">
              Tìm hiểu về TOPIK
            </h3>
            <p class="text-gray-600">
              Thông tin chi tiết về kỳ thi TOPIK, cách tính điểm, và phương pháp làm bài
            </p>
          </div>
        </div>
      </a>

      <a 
        href="/topik/kien-thuc"
        class="block p-6 bg-white rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 border-2 border-indigo-200 hover:border-indigo-400 transform hover:-translate-y-1"
      >
        <div class="flex items-center gap-4">
          <div class="w-16 h-16 bg-gradient-to-br from-indigo-500 to-purple-600 rounded-xl flex items-center justify-center">
            <span class="text-3xl">💡</span>
          </div>
          <div>
            <h3 class="text-xl font-bold text-gray-900 mb-1">
              Kiến thức
            </h3>
            <p class="text-gray-600">
              Tổng hợp kiến thức về TOPIK - Ngữ pháp, Từ vựng, Kỹ năng làm bài
            </p>
          </div>
        </div>
      </a>

      <a 
        href="/topik/luyen-tap"
        class="block p-6 bg-white rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 border-2 border-blue-200 hover:border-blue-400 transform hover:-translate-y-1"
      >
        <div class="flex items-center gap-4">
          <div class="w-16 h-16 bg-gradient-to-br from-blue-500 to-cyan-600 rounded-xl flex items-center justify-center">
            <span class="text-3xl">✏️</span>
          </div>
          <div>
            <h3 class="text-xl font-bold text-gray-900 mb-1">
              Luyện tập
            </h3>
            <p class="text-gray-600">
              Luyện tập từng dạng bài thi TOPIK với các câu hỏi có giải thích chi tiết
            </p>
          </div>
        </div>
      </a>

      <a 
        href="/topik/thi-thu"
        class="block p-6 bg-white rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 border-2 border-green-200 hover:border-green-400 transform hover:-translate-y-1"
      >
        <div class="flex items-center gap-4">
          <div class="w-16 h-16 bg-gradient-to-br from-green-500 to-emerald-600 rounded-xl flex items-center justify-center">
            <span class="text-3xl">📝</span>
          </div>
          <div>
            <h3 class="text-xl font-bold text-gray-900 mb-1">
              Thi thử
            </h3>
            <p class="text-gray-600">
              Làm đề thi thử TOPIK đầy đủ để kiểm tra trình độ và làm quen với format thi
            </p>
          </div>
        </div>
      </a>
    </div>
  </div>
</TopikLayout>
