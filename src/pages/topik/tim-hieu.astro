---
export const prerender = true;
import TopikLayout from '../../layouts/TopikLayout.astro';
---

<TopikLayout 
  title="Tìm hiểu về TOPIK" 
  description="Thông tin chi tiết về kỳ thi TOPIK - Test of Proficiency in Korean"
>
  <!-- Global Background -->
  <div class="fixed inset-0 z-0 bg-gradient-to-br from-indigo-50 via-white to-purple-50 pointer-events-none"></div>
  <div class="fixed inset-0 z-0 bg-[url('/grid.svg')] opacity-[0.2] pointer-events-none"></div>

  <!-- Back Button -->
  <a href="/topik" class="fixed top-24 left-4 z-50 p-3 bg-white/80 backdrop-blur-md border border-white/50 rounded-full shadow-lg hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group">
    <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24" class="text-indigo-600 group-hover:scale-110 transition-transform">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
    </svg>
    <span class="sr-only">Quay lại</span>
  </a>



  <!-- Main Content -->
  <main class="relative z-10 container mx-auto px-4 py-20 pb-40 max-w-4xl">
    
    <!-- Hero Section -->
    <header class="text-center mb-32 section-animate opacity-0 translate-y-8">
      <div class="inline-block mb-4 px-4 py-1.5 rounded-full bg-indigo-100/80 border border-indigo-200 text-indigo-700 font-medium text-sm backdrop-blur-sm">
        Test of Proficiency in Korean
      </div>
      <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight text-gray-900 mb-6 leading-tight">
        Chinh phục đỉnh cao <br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-600 to-purple-600">TOPIK</span>
      </h1>
      <p class="text-xl md:text-2xl text-gray-600 max-w-2xl mx-auto leading-relaxed">
        Hướng dẫn toàn diện về kỳ thi năng lực tiếng Hàn TOPIK: Từ cấu trúc, thang điểm đến chiến lược ôn thi hiệu quả.
      </p>
    </header>

    <!-- Section: TOPIK là gì -->
    <section id="topik-la-gi" class="glass-card mb-16 section-animate opacity-0 translate-y-8">
      <div class="p-8 md:p-12">
        <div class="flex items-center gap-3 mb-6">
            <div class="w-12 h-12 bg-indigo-100 rounded-xl flex items-center justify-center text-2xl">🎯</div>
            <h2 class="section-title mb-0">TOPIK là gì?</h2>
        </div>
        
        <p class="text-lg text-gray-700 leading-loose mb-8">
          TOPIK (Test of Proficiency in Korean) là kỳ thi đánh giá năng lực tiếng Hàn do <strong class="text-indigo-600">Viện Giáo dục Quốc tế Quốc gia Hàn Quốc (NIIED)</strong> tổ chức. Đây là chứng chỉ tiếng Hàn chính thức được công nhận rộng rãi trên toàn thế giới.
        </p>
        
        <div class="bg-indigo-50/50 border border-indigo-100 rounded-xl p-6">
            <h3 class="font-bold text-lg text-gray-900 mb-4">Tại sao nên thi TOPIK?</h3>
            <ul class="grid md:grid-cols-2 gap-4">
                <li class="flex items-start gap-3">
                    <span class="text-xl">📖</span>
                    <span><strong class="text-gray-900">Du học:</strong> Yêu cầu bắt buộc cho Đại học/Sau Đại học.</span>
                </li>
                <li class="flex items-start gap-3">
                    <span class="text-xl">💼</span>
                    <span><strong class="text-gray-900">Xin việc:</strong> Chứng chỉ cần thiết tại công ty Hàn Quốc.</span>
                </li>
                <li class="flex items-start gap-3">
                    <span class="text-xl">🏠</span>
                    <span><strong class="text-gray-900">Định cư:</strong> Điều kiện quan trọng để xin visa F-5.</span>
                </li>
                <li class="flex items-start gap-3">
                    <span class="text-xl">📜</span>
                    <span><strong class="text-gray-900">Chứng minh:</strong> Thước đo năng lực chuẩn quốc tế.</span>
                </li>
            </ul>
        </div>
      </div>
    </section>

    <!-- Section: TOPIK I & II -->
    <section id="topik-i-ii" class="mb-16 section-animate opacity-0 translate-y-8">
      <h2 class="text-3xl font-bold text-gray-900 mb-8 px-4 border-l-4 border-indigo-500">Cấu trúc đề thi</h2>
      <div class="grid lg:grid-cols-2 gap-8">
        <!-- TOPIK I -->
        <div class="glass-card p-8 border-t-4 border-t-green-500">
          <div class="flex items-center justify-between mb-6">
            <h3 class="text-2xl font-bold text-gray-800">TOPIK I</h3>
            <span class="px-3 py-1 bg-green-100 text-green-700 rounded-full text-sm font-semibold">Cấp 1-2</span>
          </div>
          <p class="text-gray-600 mb-4 text-sm">Dành cho người mới bắt đầu học tiếng Hàn.</p>
          <ul class="space-y-4">
            <li class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
              <div class="flex items-center">
                  <span class="text-xl mr-3">🎧</span>
                  <span class="font-bold text-gray-900">Nghe</span>
              </div>
              <span class="text-sm text-gray-600">30 câu / 40 phút</span>
            </li>
            <li class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
              <div class="flex items-center">
                  <span class="text-xl mr-3">📖</span>
                  <span class="font-bold text-gray-900">Đọc</span>
              </div>
              <span class="text-sm text-gray-600">40 câu / 60 phút</span>
            </li>
          </ul>
          <div class="mt-8 pt-6 border-t border-gray-100 grid grid-cols-3 gap-2 text-center text-sm">
             <div><div class="font-bold text-gray-900 text-lg">70</div><div class="text-xs text-gray-500">Câu</div></div>
             <div><div class="font-bold text-gray-900 text-lg">100</div><div class="text-xs text-gray-500">Phút</div></div>
             <div><div class="font-bold text-green-600 text-lg">200</div><div class="text-xs text-gray-500">Điểm tối đa</div></div>
          </div>
        </div>

        <!-- TOPIK II -->
        <div class="glass-card p-8 border-t-4 border-t-blue-500">
          <div class="flex items-center justify-between mb-6">
            <h3 class="text-2xl font-bold text-gray-800">TOPIK II</h3>
            <span class="px-3 py-1 bg-blue-100 text-blue-700 rounded-full text-sm font-semibold">Cấp 3-6</span>
          </div>
          <p class="text-gray-600 mb-4 text-sm">Dành cho trình độ trung cấp và cao cấp.</p>
          <ul class="space-y-4">
             <li class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
              <div class="flex items-center">
                  <span class="text-xl mr-3">🎧</span>
                  <span class="font-bold text-gray-900">Nghe</span>
              </div>
              <span class="text-sm text-gray-600">50 câu / 60 phút</span>
            </li>
            <li class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
              <div class="flex items-center">
                  <span class="text-xl mr-3">✍️</span>
                  <span class="font-bold text-gray-900">Viết</span>
              </div>
              <span class="text-sm text-gray-600">4 câu / 50 phút</span>
            </li>
            <li class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
              <div class="flex items-center">
                  <span class="text-xl mr-3">📖</span>
                  <span class="font-bold text-gray-900">Đọc</span>
              </div>
              <span class="text-sm text-gray-600">50 câu / 70 phút</span>
            </li>
          </ul>
          <div class="mt-8 pt-6 border-t border-gray-100 grid grid-cols-3 gap-2 text-center text-sm">
             <div><div class="font-bold text-gray-900 text-lg">104</div><div class="text-xs text-gray-500">Câu</div></div>
             <div><div class="font-bold text-gray-900 text-lg">180</div><div class="text-xs text-gray-500">Phút</div></div>
             <div><div class="font-bold text-blue-600 text-lg">300</div><div class="text-xs text-gray-500">Điểm tối đa</div></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Section: Lịch thi -->
    <section id="lich-thi" class="glass-card p-8 md:p-12 mb-16 section-animate opacity-0 translate-y-8 bg-gradient-to-r from-orange-50 to-red-50/30">
        <div class="flex items-center gap-3 mb-6">
            <div class="w-12 h-12 bg-orange-100 rounded-xl flex items-center justify-center text-2xl">📅</div>
            <h2 class="section-title mb-0">Lịch thi & Lệ phí</h2>
        </div>
        
        <div class="grid md:grid-cols-2 gap-8">
            <div>
                <h3 class="font-bold text-gray-900 text-lg mb-3">Lịch thi TOPIK</h3>
                <p class="text-gray-700 mb-4">
                    Tổ chức <strong class="text-indigo-600">6 lần/năm</strong> tại Hàn Quốc. Tại Việt Nam thường có 4 kỳ thi vào tháng <strong>4, 7, 10, 11</strong>.
                </p>
                <ul class="space-y-2 text-sm text-gray-600">
                    <li class="flex gap-2"><span>📝</span> <span>Đăng ký trước 1-2 tháng trên <a href="https://iigvietnam.com/ky-thi-topik/" target="_blank" rel="noopener" class="text-indigo-600 underline hover:text-indigo-800">website IIG Vietnam</a>.</span></li>
                    <li class="flex gap-2"><span>🏢</span> <span>Tổ chức bởi IIG Vietnam (ủy quyền bởi NIIED).</span></li>
                    <li class="flex gap-2"><span>⏳</span> <span><strong>Hiệu lực chứng chỉ:</strong> 2 năm kể từ ngày công bố kết quả.</span></li>
                </ul>
            </div>
            
            <div>
                <h3 class="font-bold text-gray-900 text-lg mb-3">Lệ phí thi (Tham khảo)</h3>
                <div class="space-y-3">
                    <div class="flex items-center justify-between p-3 bg-white rounded-lg shadow-sm">
                        <span class="font-medium text-gray-900">TOPIK I</span>
                        <span class="font-bold text-orange-600">550,000 VNĐ</span>
                    </div>
                    <div class="flex items-center justify-between p-3 bg-white rounded-lg shadow-sm">
                        <span class="font-medium text-gray-900">TOPIK II</span>
                        <span class="font-bold text-orange-600">770,000 VNĐ</span>
                    </div>
                </div>
                <p class="mt-2 text-xs text-gray-500 italic">* Lệ phí có thể thay đổi, vui lòng kiểm tra tại iigvietnam.com</p>
            </div>
        </div>
    </section>

    <!-- Section: Cách tính điểm -->
    <section id="diem" class="glass-card p-8 mb-16 section-animate opacity-0 translate-y-8">
        <div class="flex items-center gap-3 mb-6">
            <div class="w-12 h-12 bg-purple-100 rounded-xl flex items-center justify-center text-2xl">📈</div>
            <h2 class="section-title mb-0">Cách tính điểm</h2>
        </div>
        
        <div class="space-y-8">
            <!-- TOPIK I -->
            <div>
                <h3 class="text-lg font-bold text-green-700 mb-3 border-b border-gray-100 pb-2">TOPIK I (Thang 200)</h3>
                <div class="grid grid-cols-2 gap-4">
                    <div class="bg-gray-50 p-4 rounded-xl text-center">
                        <div class="text-2xl font-bold text-green-600">Cấp 1</div>
                        <div class="text-sm font-medium text-gray-500">> 80 điểm</div>
                    </div>
                    <div class="bg-green-50 p-4 rounded-xl text-center border border-green-100">
                        <div class="text-2xl font-bold text-green-700">Cấp 2</div>
                        <div class="text-sm font-medium text-gray-500">> 140 điểm</div>
                    </div>
                </div>
            </div>

            <!-- TOPIK II -->
            <div>
                <h3 class="text-lg font-bold text-blue-700 mb-3 border-b border-gray-100 pb-2">TOPIK II (Thang 300)</h3>
                <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                    <div class="bg-gray-50 p-4 rounded-xl text-center">
                        <div class="text-xl font-bold text-blue-600">Cấp 3</div>
                        <div class="text-xs font-medium text-gray-500">120-149</div>
                    </div>
                    <div class="bg-blue-50 p-4 rounded-xl text-center">
                        <div class="text-xl font-bold text-blue-700">Cấp 4</div>
                        <div class="text-xs font-medium text-gray-500">150-189</div>
                    </div>
                    <div class="bg-indigo-50 p-4 rounded-xl text-center border border-indigo-100">
                        <div class="text-xl font-bold text-indigo-700">Cấp 5</div>
                        <div class="text-xs font-medium text-gray-500">190-229</div>
                    </div>
                    <div class="bg-indigo-600 p-4 rounded-xl text-center shadow-md transform scale-105">
                        <div class="text-xl font-bold text-white">Cấp 6</div>
                        <div class="text-xs font-medium text-indigo-200">230-300</div>
                    </div>
                </div>
            </div>
            
            <div class="bg-yellow-50 p-4 rounded-lg flex gap-3 text-sm text-gray-700">
                <span class="text-xl">💡</span>
                <p><strong>Lưu ý:</strong> Điểm số dựa trên số câu đúng. Không có điểm trừ cho câu sai.</p>
            </div>
        </div>
    </section>

    <!-- Section: Tiêu chí đánh giá tổng thể -->
    <section id="tieu-chi" class="mb-16 section-animate opacity-0 translate-y-8">
        <h2 class="text-3xl font-bold text-gray-900 mb-8 px-4 border-l-4 border-indigo-500">Tiêu chí đánh giá tổng thể</h2>
        
        <div class="space-y-6">
            <!-- Level 1 -->
            <div class="glass-card p-6 border-l-4 border-green-500">
                <div class="flex flex-col md:flex-row md:items-center gap-4 mb-3">
                    <h3 class="text-xl font-bold text-gray-900">Cấp 1</h3>
                    <span class="text-sm font-semibold text-green-600 bg-green-50 px-3 py-1 rounded-full w-fit">> 80 điểm</span>
                </div>
                <p class="text-gray-600 leading-relaxed">
                    Có thể thực hiện hội thoại sinh tồn cơ bản (tự giới thiệu, mua sắm). Hiểu chủ đề cá nhân quen thuộc. Vốn từ ~800 từ. Ngữ pháp cơ bản.
                </p>
            </div>

            <!-- Level 2 -->
            <div class="glass-card p-6 border-l-4 border-green-600">
                <div class="flex flex-col md:flex-row md:items-center gap-4 mb-3">
                    <h3 class="text-xl font-bold text-gray-900">Cấp 2</h3>
                    <span class="text-sm font-semibold text-green-700 bg-green-50 px-3 py-1 rounded-full w-fit">> 140 điểm</span>
                </div>
                <p class="text-gray-600 leading-relaxed">
                    Hội thoại đơn giản về thói quen hàng ngày, sử dụng cơ sở công cộng. Phân biệt được tình huống trang trọng/không trang trọng. Vốn từ ~1,500-2,000.
                </p>
            </div>

            <!-- Level 3 -->
            <div class="glass-card p-6 border-l-4 border-blue-500">
                <div class="flex flex-col md:flex-row md:items-center gap-4 mb-3">
                    <h3 class="text-xl font-bold text-gray-900">Cấp 3</h3>
                    <span class="text-sm font-semibold text-blue-600 bg-blue-50 px-3 py-1 rounded-full w-fit">> 120 điểm</span>
                </div>
                <p class="text-gray-600 leading-relaxed">
                    Duy trì mối quan hệ xã hội cơ bản. Hiểu và diễn đạt các chủ đề xã hội quen thuộc. Phân biệt văn nói và văn viết cơ bản.
                </p>
            </div>

            <!-- Level 4 -->
            <div class="glass-card p-6 border-l-4 border-blue-600">
                <div class="flex flex-col md:flex-row md:items-center gap-4 mb-3">
                    <h3 class="text-xl font-bold text-gray-900">Cấp 4</h3>
                    <span class="text-sm font-semibold text-blue-700 bg-blue-50 px-3 py-1 rounded-full w-fit">> 150 điểm</span>
                </div>
                <p class="text-gray-600 leading-relaxed">
                    Hiểu tin tức, báo chí đơn giản. Có khả năng hiểu các chủ đề xã hội, văn hóa và thành ngữ thường gặp. Giao tiếp trôi chảy trong công việc thông thường.
                </p>
            </div>

             <!-- Level 5 -->
            <div class="glass-card p-6 border-l-4 border-indigo-500">
                <div class="flex flex-col md:flex-row md:items-center gap-4 mb-3">
                    <h3 class="text-xl font-bold text-gray-900">Cấp 5</h3>
                    <span class="text-sm font-semibold text-indigo-600 bg-indigo-50 px-3 py-1 rounded-full w-fit">> 190 điểm</span>
                </div>
                <p class="text-gray-600 leading-relaxed">
                    Có khả năng ngôn ngữ cho nghiên cứu và công việc chuyên môn. Hiểu các chủ đề chính trị, kinh tế, xã hội không quen thuộc. Sử dụng phù hợp ngữ cảnh.
                </p>
            </div>

             <!-- Level 6 -->
            <div class="glass-card p-6 border-l-4 border-purple-600">
                <div class="flex flex-col md:flex-row md:items-center gap-4 mb-3">
                    <h3 class="text-xl font-bold text-gray-900">Cấp 6</h3>
                    <span class="text-sm font-semibold text-purple-700 bg-purple-50 px-3 py-1 rounded-full w-fit">> 230 điểm</span>
                </div>
                <p class="text-gray-600 leading-relaxed">
                    Thực hiện chức năng chuyên môn chính xác và trôi chảy. Hiểu sâu rộng các chủ đề phức tạp. Giao tiếp tự nhiên gần như người bản xứ.
                </p>
            </div>
        </div>
    </section>

    <!-- Section: Tiêu chí Nghe -->
    <section id="tieu-chi-nghe" class="glass-card mb-16 section-animate opacity-0 translate-y-8">
        <div class="p-8">
            <div class="flex items-center gap-3 mb-6">
                <div class="w-10 h-10 bg-red-100 rounded-lg flex items-center justify-center text-xl">🎧</div>
                <h2 class="text-2xl font-bold text-gray-900">Tiêu chí đánh giá môn Nghe</h2>
            </div>
            
            <div class="bg-gray-50 rounded-xl p-6 mb-8">
                <h3 class="font-bold text-lg text-gray-900 mb-4">🎯 Chiến lược làm bài</h3>
                <ul class="space-y-4">
                    <li class="flex gap-3">
                        <span class="text-green-500 font-bold">✓</span>
                        <p class="text-gray-700 text-sm"><strong class="text-gray-900">Đọc trước câu hỏi:</strong> Tận dụng thời gian nghỉ để đọc lướt câu hỏi và đáp án, dự đoán nội dung.</p>
                    </li>
                    <li class="flex gap-3">
                        <span class="text-green-500 font-bold">✓</span>
                        <p class="text-gray-700 text-sm"><strong class="text-gray-900">Bắt từ khóa:</strong> Không cần nghe hết 100% từ, hãy tập trung vào các từ khóa chính và mạch câu chuyện.</p>
                    </li>
                     <li class="flex gap-3">
                        <span class="text-green-500 font-bold">✓</span>
                        <p class="text-gray-700 text-sm"><strong class="text-gray-900">Chiến thuật 50 điểm:</strong> Với TOPIK II, hãy tập trung làm đúng hoàn hảo 25 câu đầu (vùng Cấp 3-4) để nắm chắc 50 điểm cơ bản.</p>
                    </li>
                </ul>
            </div>

            <div class="grid md:grid-cols-2 gap-6 text-sm">
                <div>
                    <h4 class="font-bold text-red-500 mb-2 uppercase text-xs tracking-wider">Cấp 1-2</h4>
                    <p class="text-gray-600">Nghe hiểu hội thoại sinh hoạt hàng ngày, chủ đề cá nhân. Câu văn đơn giản, tốc độ chậm.</p>
                </div>
                <div>
                     <h4 class="font-bold text-red-500 mb-2 uppercase text-xs tracking-wider">Cấp 3-4</h4>
                    <p class="text-gray-600">Hội thoại nơi công cộng, tin tức đơn giản, phỏng vấn. Tốc độ tự nhiên hơn.</p>
                </div>
                <div>
                     <h4 class="font-bold text-red-500 mb-2 uppercase text-xs tracking-wider">Cấp 5-6</h4>
                    <p class="text-gray-600">Bài giảng, thuyết trình, tin tức chuyên sâu về chính trị, xã hội, văn hóa. Tốc độ nhanh, từ vựng cao cấp.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Section: Tiêu chí Đọc -->
    <section id="tieu-chi-doc" class="glass-card mb-16 section-animate opacity-0 translate-y-8">
        <div class="p-8">
            <div class="flex items-center gap-3 mb-6">
                <div class="w-10 h-10 bg-teal-100 rounded-lg flex items-center justify-center text-xl">📖</div>
                <h2 class="text-2xl font-bold text-gray-900">Tiêu chí đánh giá môn Đọc</h2>
            </div>
            
            <div class="grid md:grid-cols-2 gap-6">
                <div class="p-4 bg-teal-50/50 rounded-xl">
                    <h3 class="font-bold text-teal-800 mb-2">TOPIK I (Câu 31-70)</h3>
                    <ul class="space-y-2 text-sm text-gray-700">
                        <li>• Biển báo, mẩu tin nhắn, quảng cáo ngắn.</li>
                        <li>• Đọc hiểu nội dung cốt lõi của đoạn văn sinh hoạt.</li>
                        <li>• Nắm bắt thông tin chi tiết (cái gì, ở đâu, khi nào).</li>
                    </ul>
                </div>
                <div class="p-4 bg-teal-50/50 rounded-xl">
                    <h3 class="font-bold text-teal-800 mb-2">TOPIK II (Câu 1-50)</h3>
                    <ul class="space-y-2 text-sm text-gray-700">
                        <li>• Báo chí, hướng dẫn sử dụng, bài tiểu luận (Cấp 3-4).</li>
                        <li>• Văn bản chuyên môn, giải thích, nghị luận (Cấp 5-6).</li>
                        <li>• Đánh giá khả năng suy luận và tư duy phê phán.</li>
                        <li>• Hiểu tâm lý tác giả trong tác phẩm văn học.</li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- Section: Tiêu chí Viết -->
    <section id="tieu-chi-viet" class="glass-card mb-24 section-animate opacity-0 translate-y-8">
        <div class="p-8">
            <div class="flex items-center gap-3 mb-6">
                <div class="w-10 h-10 bg-amber-100 rounded-lg flex items-center justify-center text-xl">✍️</div>
                <h2 class="text-2xl font-bold text-gray-900">Chiến lược môn Viết (TOPIK II)</h2>
            </div>

            <div class="mb-8 p-4 bg-amber-50 border-l-4 border-amber-500 rounded-r-lg">
                <p class="text-gray-700 text-sm">
                    <strong>Mục tiêu Cấp 3-4:</strong> Tập trung tối đa vào <strong>Câu 51, 52 và 53</strong> để lấy trọn vẹn <strong>50 điểm</strong>. Câu 54 chỉ cần viết cơ bản.
                </p>
            </div>
            
            <div class="space-y-8">
                <div>
                    <h3 class="text-lg font-bold text-gray-900 mb-2 border-b border-gray-100 pb-2">1. Câu 51-52: Điền vào chỗ trống (20đ)</h3>
                    <p class="text-gray-600 text-sm mb-2">Điền từ hoặc cụm từ phù hợp vào hội thoại/văn bản ngắn.</p>
                    <ul class="text-sm text-gray-600 list-disc ml-5">
                        <li>Hiểu mạch văn và ngữ cảnh.</li>
                        <li>Phân biệt đuôi câu trang trọng (kính ngữ) và thân mật.</li>
                        <li>Nắm vững các cặp ngữ pháp hô ứng.</li>
                    </ul>
                </div>

                <div>
                    <h3 class="text-lg font-bold text-gray-900 mb-2 border-b border-gray-100 pb-2">2. Câu 53: Phân tích biểu đồ (30đ)</h3>
                    <p class="text-gray-600 text-sm mb-4">Chuyển đổi dữ liệu biểu đồ thành đoạn văn 200-300 chữ.</p>
                    
                    <div class="bg-indigo-50 p-4 rounded-lg text-sm mb-4">
                        <strong class="text-indigo-700">🎯 Mẫu câu vàng (Templates):</strong>
                        <ul class="mt-2 space-y-2 text-gray-700">
                            <li>• <strong>Tăng:</strong> ~(으)ㄴ/는 것으로 나타났다 (được cho thấy là...)</li>
                            <li>• <strong>Giảm:</strong> ~(으)ㄴ/는 반면(에) (ngược lại...)</li>
                            <li>• <strong>So sánh:</strong> ~에 비해 / ~보다 (so với...)</li>
                            <li>• <strong>Nguyên nhân:</strong> ~기 때문이다 / ~(으)ㄴ/는 것으로 보인다</li>
                            <li>• <strong>Kết luận:</strong> 이러한 결과를 통해 ~을/를 알 수 있다</li>
                        </ul>
                    </div>
                    
                    <div class="bg-gray-50 p-4 rounded-lg text-sm">
                        <strong class="text-green-600">💡 Mẹo:</strong> Học thuộc các mẫu câu trên. Đây là câu <strong>dễ lấy điểm nhất</strong> nếu có công thức sẵn!
                    </div>
                </div>

                <div>
                    <h3 class="text-lg font-bold text-gray-900 mb-2 border-b border-gray-100 pb-2">3. Câu 54: Bài luận xã hội (50đ)</h3>
                    <p class="text-gray-600 text-sm mb-2">Viết bài nghị luận 600-700 chữ về chủ đề xã hội.</p>
                    <ul class="text-sm text-gray-600 list-disc ml-5">
                        <li>Cấu trúc 3 phần: Mở bài - Thân bài (giải quyết 2-3 ý) - Kết bài.</li>
                        <li>Sử dụng từ nối (Transition words): Tuy nhiên, Hơn nữa, Vì vậy...</li>
                        <li>Dùng từ vựng Hán Hàn để tăng tính chuyên môn.</li>
                    </ul>
                </div>
            </div>
            
            <div class="mt-8 pt-6 border-t border-gray-100">
                <h4 class="font-bold text-gray-800 mb-2">Quy tắc giấy kẻ ô (Wongoji)</h4>
                <div class="grid grid-cols-2 md:grid-cols-4 gap-2 text-xs text-gray-500">
                    <div class="bg-gray-50 p-2 rounded">Số: 2 chữ số / 1 ô</div>
                    <div class="bg-gray-50 p-2 rounded">Dấu câu: 1 ô riêng</div>
                    <div class="bg-gray-50 p-2 rounded">Đoạn mới: Lùi 1 ô</div>
                    <div class="bg-gray-50 p-2 rounded">Sau dấu !?: Cách 1 ô</div>
                </div>
            </div>
        </div>
    </section>

    <!-- Call to Action -->
    <section class="text-center pb-20 p-8 section-animate opacity-0 translate-y-8">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">Sẵn sàng chinh phục TOPIK?</h2>
        <p class="text-gray-600 mb-8">Bắt đầu hành trình của bạn ngay hôm nay với kho tài liệu miễn phí.</p>
        <a href="/topik" class="inline-flex items-center justify-center px-8 py-3 bg-indigo-600 text-white font-bold rounded-full hover:bg-indigo-700 hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
            Xem tài liệu học TOPIK
        </a>
    </section>

  </main>

</TopikLayout>

<style>
  /* Glassmorphism Utilities */
  .glass-card {
    background: rgba(255, 255, 255, 0.75);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.6);
    border-radius: 1.5rem;
    box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.05);
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  
  .glass-card:hover {
    box-shadow: 0 20px 40px -10px rgba(0, 0, 0, 0.08);
  }

  .section-title {
    font-size: 1.875rem;
    font-weight: 800;
    color: #111827;
    margin-bottom: 1.5rem;
    letter-spacing: -0.025em;
  }

  /* Navigation Links */
  .nav-link {
    display: block;
    padding: 0.5rem 0.75rem;
    color: #6b7280;
    text-decoration: none;
    border-radius: 0.5rem;
    transition: all 0.2s;
  }

  .nav-link:hover {
    background: rgba(99, 102, 241, 0.1);
    color: #4f46e5;
  }

  .nav-link.active {
    background: rgba(99, 102, 241, 0.1);
    color: #4f46e5;
    font-weight: 600;
  }

  /* Smooth Reveal Animation */
  .section-animate {
    transition: opacity 0.8s ease-out, transform 0.8s ease-out;
    will-change: opacity, transform;
  }
  
  .section-animate.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  // Intersection Observer for fade-in animations
  const observerOptions = {
    root: null,
    rootMargin: '0px',
    threshold: 0.1
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  }, observerOptions);

  document.querySelectorAll('.section-animate').forEach((section) => {
    observer.observe(section);
  });

  // Active Table of Contents highlighting
  const sectionObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const id = entry.target.getAttribute('id');
        document.querySelectorAll('.nav-link').forEach(link => {
            link.classList.remove('active');
            if (link.getAttribute('href') === `#${id}`) {
                link.classList.add('active');
            }
        });
      }
    });
  }, { rootMargin: '-20% 0px -60% 0px' });

  document.querySelectorAll('section[id]').forEach((section) => {
    sectionObserver.observe(section);
  });
</script>
