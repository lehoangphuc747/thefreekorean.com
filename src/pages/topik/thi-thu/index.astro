---
export const prerender = true;
import TopikLayout from '../../../layouts/TopikLayout.astro';
import { getCollection } from 'astro:content';

const exams = (await getCollection('thi-thu'))
  .map(entry => ({
    slug: entry.id,
    title: entry.data.meta.title,
    level: entry.data.meta.level,
    duration: entry.data.meta.duration,
    totalQuestions: entry.data.meta.totalQuestions,
    description: entry.data.meta.description || '',
  }))
  .sort((a, b) => a.title.localeCompare(b.title));
---

<TopikLayout 
  title="Thi thử TOPIK"
  description="Làm đề thi thử TOPIK đầy đủ để kiểm tra trình độ và làm quen với format thi"
>
  <div class="max-w-7xl mx-auto px-4 py-12">
    <!-- Back to TOPIK button -->
    <a 
      href="/topik"
      class="inline-flex items-center gap-2 text-blue-600 hover:text-blue-700 mb-6 transition-colors"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      <span>Quay lại trang TOPIK</span>
    </a>

    <div class="text-center mb-12">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">
        Thi thử TOPIK
      </h1>
      <p class="text-xl text-gray-600">
        Làm đề thi thử TOPIK đầy đủ để kiểm tra trình độ và làm quen với format thi
      </p>
    </div>

    {exams.length === 0 ? (
      <div class="max-w-4xl mx-auto text-center py-16">
        <div class="bg-yellow-50 border-2 border-yellow-200 rounded-xl p-8">
          <p class="text-lg text-gray-700 mb-4">
            📝 Chưa có đề thi thử nào.
          </p>
          <p class="text-gray-600">
            Các đề thi thử sẽ được thêm vào thư mục <code class="bg-gray-100 px-2 py-1 rounded">src/content/topik/thi-thu/</code>
          </p>
        </div>
      </div>
    ) : (
      <div class="max-w-4xl mx-auto grid gap-6">
        {exams.map((exam) => (
          <a 
            href={`/topik/thi-thu/${exam.slug}`}
            class="block bg-white rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 border-2 border-green-200 hover:border-green-400 transform hover:-translate-y-1"
          >
            <div class="p-6">
              <div class="flex items-start justify-between">
                <div class="flex-1">
                  <h3 class="text-xl font-bold text-gray-900 mb-2">
                    {exam.title}
                  </h3>
                  {exam.description && (
                    <p class="text-gray-600 mb-4">
                      {exam.description}
                    </p>
                  )}
                  <div class="flex items-center gap-4 flex-wrap">
                    <span class="px-3 py-1 bg-green-100 text-green-700 rounded-full text-sm font-medium">
                      {exam.level}
                    </span>
                    <span class="text-sm text-gray-500">
                      ⏱️ {exam.duration} phút
                    </span>
                    <span class="text-sm text-gray-500">
                      📝 {exam.totalQuestions} câu
                    </span>
                  </div>
                </div>
                <svg class="w-6 h-6 text-gray-400 ml-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    )}
  </div>
</TopikLayout>
