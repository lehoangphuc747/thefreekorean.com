---
export const prerender = true;
import TopikLayout from '../../../../layouts/TopikLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const exams = await getCollection('thi-thu');
  return exams.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const slug = entry.id;
---

<TopikLayout title="쓰기 (Writing) - TOPIK">
  <div class="max-w-4xl mx-auto px-4 py-8">
    <!-- Back -->
    <a href={`/topik/thi-thu/${slug}`} class="inline-flex items-center gap-2 text-blue-600 hover:text-blue-700 mb-4 transition-colors">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
      <span>Quay lại</span>
    </a>

    <!-- Header -->
    <div class="bg-white rounded-xl shadow-lg p-6 mb-6">
      <h1 class="text-2xl font-bold text-gray-900 mb-2">쓰기 Writing</h1>
      <p class="text-gray-600">4 câu hỏi • 50 phút</p>
    </div>

    <!-- Timer -->
    <div id="timer-bar" class="sticky z-40 bg-white shadow-md rounded-lg px-4 py-3 mb-4 flex items-center justify-between" style="top: 0.5rem;">
      <div class="flex items-center gap-4">
        <span class="font-bold text-gray-800">✍️ Writing</span>
        <span id="timer" class="text-xl font-mono text-red-600 font-bold">50:00</span>
      </div>
      <div class="flex items-center gap-3">
        <span id="progress-text" class="text-sm text-gray-500">0/4 câu</span>
        <button id="btn-submit" class="px-4 py-2 bg-blue-600 text-white text-sm font-semibold rounded-lg hover:bg-blue-700 transition-colors">Nộp bài</button>
      </div>
    </div>

    <!-- Questions -->
    <div id="questions-area" class="space-y-6"></div>

    <!-- Results -->
    <div id="results-area" class="hidden bg-white rounded-xl shadow-lg p-8">
      <h2 class="text-2xl font-bold mb-4 text-center">Kết quả</h2>
      <p class="text-gray-600 text-center mb-6">Đối chiếu bài làm với mẫu tham khảo bên dưới</p>
      <div id="results-content"></div>
      <div class="text-center mt-6">
        <a href={`/topik/thi-thu/${slug}/writing`} class="inline-block px-6 py-3 bg-blue-600 text-white font-bold rounded-lg hover:bg-blue-700 transition-colors">Làm lại</a>
      </div>
    </div>
  </div>
</TopikLayout>

<script is:inline>
fetch(`/topik2-thi-thu-35-writing.json`)
  .then(r => r.json())
  .then(data => initWriting(data))
  .catch(err => console.error('Failed to load:', err));

function initWriting(data) {
  const questions = data.questions;
  let answers = {};
  let submitted = false;
  let timeLeft = data.meta.duration * 60;
  let timerInterval = null;

  const timerEl = document.getElementById('timer');
  const progressText = document.getElementById('progress-text');
  const questionsArea = document.getElementById('questions-area');
  const resultsArea = document.getElementById('results-area');
  const resultsContent = document.getElementById('results-content');
  const btnSubmit = document.getElementById('btn-submit');

  // Start timer
  timerInterval = setInterval(() => {
    timeLeft--;
    const m = Math.floor(timeLeft / 60);
    const s = timeLeft % 60;
    timerEl.textContent = `${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
    timerEl.className = timeLeft < 60 ? 'text-xl font-mono text-red-700 font-bold animate-pulse' : 'text-xl font-mono text-red-600 font-bold';
    
    const answered = Object.keys(answers).filter(k => answers[k] && answers[k].trim()).length;
    progressText.textContent = `${answered}/${questions.length} câu`;
    
    if (timeLeft <= 0) {
      clearInterval(timerInterval);
      submit();
    }
  }, 1000);

  // Render
  function render() {
    let html = '';

    questions.forEach((q, qi) => {
      const key = `writing-${q.id}`;
      const text = answers[key] || '';

      html += `<div class="bg-white rounded-xl shadow-md p-6">`;
      
      // Question header
      html += `<div class="flex items-start gap-3 mb-4">
        <span class="flex-shrink-0 w-10 h-10 rounded-full bg-orange-100 text-orange-700 font-bold text-sm flex items-center justify-center">${q.id}</span>
        <div class="flex-1">
          <span class="px-2 py-1 bg-orange-100 text-orange-700 text-xs font-semibold rounded">${q.points} điểm</span>
        </div>
      </div>`;

      // Question text
      if (q.question_ko) {
        html += `<div class="bg-gray-50 p-4 rounded-lg mb-4">
          <p class="text-gray-800 whitespace-pre-line text-sm leading-relaxed">${q.question_ko}</p>
        </div>`;
      }

      // Textarea
      if (submitted) {
        // Show user's answer
        html += `<div class="mb-4">
          <p class="text-xs text-gray-500 mb-2">Bài làm của bạn:</p>
          <div class="bg-blue-50 p-4 rounded-lg">
            <p class="text-sm text-gray-800 whitespace-pre-line">${text || '(Chưa viết)'}</p>
          </div>
          <p class="text-xs text-gray-400 mt-1">${text.length} chữ</p>
        </div>`;

        // Show model answer
        if (q.model_answer) {
          html += `<div class="bg-green-50 border border-green-200 rounded-lg p-4">
            <p class="text-sm font-semibold text-green-700 mb-2">Mẫu tham khảo:</p>
            <p class="text-sm text-green-800 whitespace-pre-line leading-relaxed">${q.model_answer}</p>
          </div>`;
        }
      } else {
        // Textarea for input
        const minChars = q.minChars || 0;
        const maxChars = q.maxChars || 999;
        html += `<textarea 
          class="writing-input w-full p-4 border-2 border-gray-200 rounded-lg focus:border-orange-500 focus:outline-none resize-none text-sm" 
          rows="${q.id <= 52 ? 4 : 10}" 
          placeholder="${q.id <= 52 ? 'Viết câu trả lời...' : `Viết bài (${minChars}-${maxChars} chữ)...`}" 
          data-key="${key}"
        >${text}</textarea>`;

        if (minChars > 0) {
          html += `<div class="flex justify-between mt-2">
            <span class="text-xs text-gray-400">Yêu cầu: ${minChars}-${maxChars} chữ</span>
            <span class="char-count text-xs text-gray-400" data-key="${key}">${text.length} chữ</span>
          </div>`;
        }
      }

      html += `</div>`;
    });

    questionsArea.innerHTML = html;

    // Input handlers
    questionsArea.querySelectorAll('.writing-input').forEach(textarea => {
      textarea.addEventListener('input', () => {
        const key = textarea.dataset.key;
        answers[key] = textarea.value;
        const counter = questionsArea.querySelector(`.char-count[data-key="${key}"]`);
        if (counter) counter.textContent = `${textarea.value.length} chữ`;
      });
    });
  }

  // Submit
  function submit() {
    submitted = true;
    clearInterval(timerInterval);
    render();

    resultsArea.classList.remove('hidden');
    resultsArea.scrollIntoView({ behavior: 'smooth' });

    btnSubmit.textContent = 'Đã nộp bài';
    btnSubmit.disabled = true;
    btnSubmit.classList.add('opacity-50');
  }

  btnSubmit.addEventListener('click', () => {
    if (!submitted && confirm('Bạn có chắc muốn nộp bài?')) submit();
  });

  render();
}
</script>

<style>
  .animate-pulse { animation: pulse 1s cubic-bezier(0.4, 0, 0.6, 1) infinite; }
  @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: .5; } }
</style>
