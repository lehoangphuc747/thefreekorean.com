---
export const prerender = true;
import TopikLayout from '../../../layouts/TopikLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const exams = await getCollection('thi-thu');
  return exams.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const exam = entry.data;
---

<TopikLayout 
  title={exam.meta.title}
  description={exam.meta.description || `Thi thử TOPIK - ${exam.meta.title}`}
>
  <div class="max-w-4xl mx-auto px-4 py-12">
    <!-- Back button -->
    <a 
      href="/topik/thi-thu"
      class="inline-flex items-center gap-2 text-blue-600 hover:text-blue-700 mb-6 transition-colors"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      <span>Quay lại danh sách đề thi</span>
    </a>

    <!-- Exam Header -->
    <div class="bg-white rounded-xl shadow-lg p-8 mb-8">
      <h1 class="text-3xl font-bold text-gray-900 mb-4">
        {exam.meta.title}
      </h1>
      <div class="flex items-center gap-4 flex-wrap text-gray-600">
        <span class="px-3 py-1 bg-green-100 text-green-700 rounded-full font-medium">
          {exam.meta.level}
        </span>
        <span>⏱️ {exam.meta.duration} phút</span>
        <span>📝 {exam.meta.totalQuestions} câu</span>
      </div>
      {exam.meta.description && (
        <p class="mt-4 text-gray-600">{exam.meta.description}</p>
      )}
    </div>

    <!-- Sections -->
    <div class="space-y-8">
      {exam.sections.map((section, index) => (
        <div class="bg-white rounded-xl shadow-lg p-8">
          <div class="flex items-center justify-between mb-6">
            <h2 class="text-2xl font-bold text-gray-900">
              Phần {index + 1}: {section.title}
            </h2>
            <span class="px-3 py-1 bg-blue-100 text-blue-700 rounded-full text-sm font-medium">
              ⏱️ {section.duration} phút
            </span>
          </div>
          
          <p class="text-gray-600 mb-4">
            {section.questions.length} câu hỏi
          </p>

          <!-- Start button for this section -->
          <button 
            class="w-full py-3 px-6 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 transition-colors"
            data-section={section.type}
          >
            Bắt đầu làm phần {section.title}
          </button>
        </div>
      ))}
    </div>

    <!-- Start Full Exam Button -->
    <div class="mt-8 text-center">
      <button 
        id="start-full-exam"
        class="px-8 py-4 bg-green-600 text-white text-lg font-bold rounded-xl hover:bg-green-700 transition-colors shadow-lg"
      >
        🎯 Bắt đầu làm toàn bộ đề thi
      </button>
    </div>
  </div>
</TopikLayout>

<script define:vars={{ exam }}>
  document.addEventListener('DOMContentLoaded', () => {
    const startBtn = document.getElementById('start-full-exam');
    
    if (startBtn) {
      startBtn.addEventListener('click', () => {
        // Lưu dữ liệu exam vào localStorage để sử dụng trong trang làm bài
        localStorage.setItem('currentExam', JSON.stringify(exam));
        // Chuyển đến trang làm bài (sẽ implement sau)
        alert('Tính năng đang được phát triển. Vui lòng quay lại sau!');
      });
    }
  });
</script>
