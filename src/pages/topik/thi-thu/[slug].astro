---
export const prerender = true;
import TopikLayout from '../../../layouts/TopikLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const exams = await getCollection('thi-thu');
  return exams.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const exam = entry.data;
const slug = entry.id;
---

<TopikLayout 
  title={exam.meta.title}
  description={exam.meta.description || `Thi thử TOPIK - ${exam.meta.title}`}
>
  <div class="max-w-4xl mx-auto px-4 py-8">
    <!-- Back button -->
    <a 
      href="/topik/thi-thu"
      class="inline-flex items-center gap-2 text-blue-600 hover:text-blue-700 mb-6 transition-colors"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      <span>Quay lại danh sách đề thi</span>
    </a>

    <!-- Exam Header -->
    <div class="bg-white rounded-xl shadow-lg p-8 mb-8">
      <h1 class="text-3xl font-bold text-gray-900 mb-4">{exam.meta.title}</h1>
      <div class="flex items-center gap-4 flex-wrap text-gray-600">
        <span class="px-3 py-1 bg-green-100 text-green-700 rounded-full font-medium">{exam.meta.level}</span>
        <span>⏱️ {exam.meta.duration} phút</span>
        <span>📝 {exam.meta.totalQuestions} câu hỏi</span>
      </div>
      {exam.meta.description && <p class="mt-4 text-gray-600">{exam.meta.description}</p>}
    </div>

    <!-- Section Cards -->
    <div class="grid gap-6 md:grid-cols-3">
      <!-- Listening -->
      <a 
        href={`/topik/thi-thu/${slug}/listening`}
        class="block bg-white rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 border-2 border-purple-200 hover:border-purple-400 transform hover:-translate-y-1"
      >
        <div class="p-6">
          <div class="text-4xl mb-4">🎧</div>
          <h2 class="text-xl font-bold text-gray-900 mb-2">듣기 Listening</h2>
          <div class="space-y-2 text-sm text-gray-600">
            <p>📝 50 câu hỏi</p>
            <p>⏱️ 60 phút</p>
            <p>🔊 Có audio</p>
          </div>
          <div class="mt-4 px-4 py-2 bg-purple-600 text-white text-center font-semibold rounded-lg">
            Bắt đầu làm bài
          </div>
        </div>
      </a>

      <!-- Reading -->
      <a 
        href={`/topik/thi-thu/${slug}/reading`}
        class="block bg-white rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 border-2 border-blue-200 hover:border-blue-400 transform hover:-translate-y-1"
      >
        <div class="p-6">
          <div class="text-4xl mb-4">📖</div>
          <h2 class="text-xl font-bold text-gray-900 mb-2">읽기 Reading</h2>
          <div class="space-y-2 text-sm text-gray-600">
            <p>📝 50 câu hỏi</p>
            <p>⏱️ 50 phút</p>
            <p>📄 Đọc hiểu</p>
          </div>
          <div class="mt-4 px-4 py-2 bg-blue-600 text-white text-center font-semibold rounded-lg">
            Bắt đầu làm bài
          </div>
        </div>
      </a>

      <!-- Writing -->
      <a 
        href={`/topik/thi-thu/${slug}/writing`}
        class="block bg-white rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 border-2 border-orange-200 hover:border-orange-400 transform hover:-translate-y-1"
      >
        <div class="p-6">
          <div class="text-4xl mb-4">✍️</div>
          <h2 class="text-xl font-bold text-gray-900 mb-2">쓰기 Writing</h2>
          <div class="space-y-2 text-sm text-gray-600">
            <p>📝 4 câu hỏi</p>
            <p>⏱️ 50 phút</p>
            <p>✍️ Viết luận</p>
          </div>
          <div class="mt-4 px-4 py-2 bg-orange-600 text-white text-center font-semibold rounded-lg">
            Bắt đầu làm bài
          </div>
        </div>
      </a>
    </div>
  </div>
</TopikLayout>
